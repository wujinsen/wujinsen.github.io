---
import BrandLayout from '../../layouts/BrandLayout.astro';
import I18n from '../../components/I18n.astro';
import ContactChannels from '../../components/ContactChannels.astro';
import BuildCards from '../../components/BuildCards.astro';
import { site } from '../../data/site';
import {
  brandMeta,
  brandStats,
  brandFeatured,
  brandTopics,
  brandWritingLinks,
  brandBeliefs,
  brandProjects,
  brandPress,
} from '../../data/brand';
---

<BrandLayout title={brandMeta.title.en} description={brandMeta.description.en}>
  <nav class="nav" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="/brand/" class="logo">
        <span class="logo-mark">W</span>
        <I18n en={site.name.en} zh={site.name.zh} />
        <span class="small">
          <I18n en="· Backend notes" zh="· 后端笔记" />
        </span>
      </a>
      <div class="nav-links">
        <a href="#blog"><I18n en="Blog" zh="博客" /></a>
        <a href="#building"><I18n en="Work" zh="作品" /></a>
        <a href="#about"><I18n en="About" zh="关于" /></a>
        <a href="/#stack"><I18n en="Stack" zh="技术栈" /></a>
        <a href="#contact"><I18n en="Contact" zh="联系" /></a>
      </div>
      <div class="nav-right">
        <a href="/" class="nav-compare"><I18n en="Minimal" zh="极简版" /></a>
        <div class="lang-toggle" role="group" aria-label="Language switcher">
          <button type="button" data-set-lang="en">EN</button>
          <button type="button" data-set-lang="zh">中</button>
        </div>
      </div>
    </div>
  </nav>

  <main id="main">
    <section class="hero reveal">
      <div class="hero-grid">
        <div>
          <h1 class="hero-quote display">
            <I18n en="Fourteen years of Java backends." zh="十四年 Java 后端。" />
            <span class="markup">
              <I18n en="Notes on what broke and what shipped." zh="记录踩过的坑与上线的系统。" />
            </span>
          </h1>
          <p class="hero-byline">
            <I18n
              en="Architecture work across e-commerce, fintech, and internal SaaS."
              zh="做过电商、金融与内部 SaaS 的架构工作。"
            />
          </p>
          <div class="hero-actions">
            <a class="btn-brand-primary" href={site.blog} target="_blank" rel="noopener noreferrer">
              <I18n en="Read the blog" zh="阅读博客" />
            </a>
            <a class="btn-brand-secondary" href={`mailto:${site.email}`}>
              <I18n en="Email" zh="邮件" />
            </a>
          </div>
          <p class="hero-meta">
            <I18n en="VuePress · CN / EN / JA" zh="VuePress · 中 / 英 / 日" />
          </p>
        </div>
        <div class="hero-photo">
          <div class="hero-mark-inner">
            <span class="hero-mark-letter">W</span>
            <p class="hero-mark-caption">
              <I18n en="Java architect" zh="Java 架构师" />
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="stats reveal">
      {
        brandStats.map((stat) => (
          <div class="stat">
            <div class="stat-num">
              {typeof stat.num === 'string' ? (
                stat.num
              ) : (
                <I18n en={stat.num.en} zh={stat.num.zh} />
              )}
            </div>
            <div class="stat-label">
              <I18n en={stat.label.en} zh={stat.label.zh} />
            </div>
          </div>
        ))
      }
    </div>

    <section class="section reveal">
      <h2 class="section-title">
        <I18n en="Featured" zh="推荐" />
      </h2>
      <a class="featured" href={brandFeatured.href} target="_blank" rel="noopener noreferrer">
        <div>
          <div class="feat-tag">
            <I18n en={brandFeatured.tag.en} zh={brandFeatured.tag.zh} />
          </div>
          <h3 class="feat-title display">
            <I18n en={brandFeatured.title.en} zh={brandFeatured.title.zh} />
          </h3>
          <p class="feat-dek">
            <I18n en={brandFeatured.dek.en} zh={brandFeatured.dek.zh} />
          </p>
          <div class="feat-byline">
            {brandFeatured.byline.map((item) => (
              <span><I18n en={item.en} zh={item.zh} /></span>
            ))}
          </div>
        </div>
        <div class="feat-right">
          <div class="feat-pullquote display">
            <I18n en={brandFeatured.quote.en} zh={brandFeatured.quote.zh} />
          </div>
        </div>
      </a>
    </section>

    <section class="section reveal" id="topics" style="padding-top: 0;">
      <h2 class="section-title">
        <I18n en="Topics I write about" zh="常写的主题" />
      </h2>
      <div class="topics">
        {
          brandTopics.map((topic) => (
            <div class:list={['topic-card', { featured: topic.featured }]}>
              <div>
                <h3 class="topic-name">
                  <I18n en={topic.name.en} zh={topic.name.zh} />
                </h3>
                <p class="topic-desc">
                  <I18n en={topic.desc.en} zh={topic.desc.zh} />
                </p>
                <span class="topic-meta">
                  <I18n en={topic.meta.en} zh={topic.meta.zh} />
                </span>
              </div>
              {topic.featured ? (
                <div class="topic-visual">
                  <span class="topic-visual-line"></span>
                  <span class="topic-visual-label">Java</span>
                </div>
              ) : null}
            </div>
          ))
        }
      </div>
    </section>

    <section class="section reveal" id="blog" style="padding-top: 0;">
      <h2 class="section-title">
        <I18n en="Blog" zh="博客" />
      </h2>
      <div class="writing-links">
        {
          brandWritingLinks.map((link) => {
            const body = (
              <>
                <span class="writing-source">
                  <I18n en={link.source.en} zh={link.source.zh} />
                </span>
                <div>
                  <h3 class="writing-title">
                    <I18n en={link.title.en} zh={link.title.zh} />
                  </h3>
                </div>
              </>
            );

            return link.href ? (
              <a class="writing-row" href={link.href} target="_blank" rel="noopener noreferrer">
                {body}
              </a>
            ) : (
              <div class="writing-row writing-row-static">{body}</div>
            );
          })
        }
      </div>
    </section>

    <section class="manifesto-wrap reveal">
      <div class="manifesto">
        <h2 class="manifesto-title display">
          <I18n en="How I think about backend work" zh="我对后端工作的几条固定看法" />
        </h2>
        <div class="manifesto-grid">
          <div></div>
          <div class="manifesto-list">
            {
              brandBeliefs.map((belief) => (
                <div class="belief">
                  <h5><I18n en={belief.title.en} zh={belief.title.zh} /></h5>
                  <p><I18n en={belief.body.en} zh={belief.body.zh} /></p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="section reveal" style="padding-top: 0;">
      <div class="press-strip">
        <div class="press-label"><I18n en="Links" zh="链接" /></div>
        <div class="press-links">
          {brandPress.map((item) => (
            <a href={item.href} target="_blank" rel="noopener noreferrer">{item.label}</a>
          ))}
        </div>
      </div>
    </section>

    <section class="section reveal" id="building" style="padding-top: 24px;">
      <h2 class="section-title">
        <I18n en="Side projects" zh="个人项目" />
      </h2>
      <BuildCards projects={brandProjects} />
    </section>

    <section class="section reveal" id="contact">
      <div class="contact-band">
        <h2 class="section-title">
          <I18n en="Contact" zh="联系" />
        </h2>
        <ContactChannels />
      </div>
    </section>

    <section class="section reveal" id="about" style="padding-top: 0;">
      <h2 class="section-title">
        <I18n en="About" zh="关于" />
      </h2>
      <p class="about-bio">
        <I18n
          en="Wu Jinsen writes Java backends—fourteen years across e-commerce, fintech, and SaaS, microservices, data warehouses, and teams. BioScope3D is a WebGL side lab."
          zh="吴锦森，十四年 Java 后端，做过电商、金融与 SaaS 的微服务和数仓，带过团队。BioScope3D 是 WebGL 个人实验。"
        />
      </p>
    </section>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-left">
        <span class="logo-mark">W</span>
        <I18n en="© 2026 Wu Jinsen" zh="© 2026 吴锦森" />
      </div>
      <div class="footer-right">
        <a href={site.github} target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href={site.blog} target="_blank" rel="noopener noreferrer">Blog</a>
        <a href="/"><I18n en="Minimal" zh="极简版" /></a>
        <a data-set-lang="en">English</a>
        <a data-set-lang="zh">中文</a>
      </div>
    </div>
  </footer>
</BrandLayout>
