---
import I18n from './I18n.astro';
import { products } from '../data/site';
---

<section class="section reveal section-tight-top" id="work">
  <h2 class="section-title">
    <I18n
      en="Personal open-source projects."
      zh="个人开源项目。"
    />
  </h2>
  <div class="products-list">
    {
      products.map((product) => (
        <a
          class:list={['product-row', { reverse: product.reverse }]}
          href={product.href}
          {...(product.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          <div class="product-thumb">
            {product.image ? (
              <img
                src={product.image}
                alt={product.imageAlt}
                width="560"
                height="350"
                loading="lazy"
                style={product.imageFit ? `object-fit: ${product.imageFit}` : undefined}
              />
            ) : (
              <div class="product-mark" aria-hidden="true">{product.name.slice(0, 1)}</div>
            )}
          </div>
          <div class="product-body">
            <h3>{product.name}</h3>
            <div class="product-meta">
              <I18n en={product.meta.en} zh={product.meta.zh} />
            </div>
            <p>
              <I18n en={product.description.en} zh={product.description.zh} />
            </p>
            <div class="product-tech">
              {product.tech.map((tech) => (
                <span class="tech-pill">{tech}</span>
              ))}
            </div>
          </div>
        </a>
      ))
    }
  </div>
</section>
