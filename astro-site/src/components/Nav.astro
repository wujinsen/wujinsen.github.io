---
import I18n from './I18n.astro';
import { site } from '../data/site';
---

<nav class="nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="logo">
      <span class="logo-mark">W</span>
      <I18n en={site.name.en} zh={site.name.zh} />
    </a>
    <div class="nav-links">
      <a href="#work"><I18n en="Work" zh="作品" /></a>
      <a href="#blog"><I18n en="Blog" zh="博客" /></a>
      <a href="#about"><I18n en="About" zh="关于" /></a>
      <a href="#stack"><I18n en="Stack" zh="技术栈" /></a>
      <a href="#contact"><I18n en="Contact" zh="联系" /></a>
    </div>
    <div class="nav-right">
      <a href="/brand/" class="nav-compare"><I18n en="Brand" zh="写作版" /></a>
      <div class="lang-toggle" role="group" aria-label="Language switcher">
        <button type="button" data-set-lang="en">EN</button>
        <button type="button" data-set-lang="zh">中</button>
      </div>
    </div>
  </div>
</nav>
