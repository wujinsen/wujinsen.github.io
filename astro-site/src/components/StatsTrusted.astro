---
import I18n from './I18n.astro';
import { stats, trustedCompanies } from '../data/site';
---

<div class="stats reveal">
  {
    stats.map((stat) => (
      <div class="stat">
        <div class="stat-num">
          {typeof stat.num === 'string' ? (
            stat.num
          ) : (
            <I18n en={stat.num.en} zh={stat.num.zh} />
          )}
        </div>
        <div class="stat-label">
          <I18n en={stat.label.en} zh={stat.label.zh} />
        </div>
      </div>
    ))
  }
</div>

<section class="trusted reveal" aria-label="Companies">
  <p>
    <I18n en="Trusted in production by teams at" zh="曾在以下团队的生产环境中服务" />
  </p>
  <div class="trusted-logos">
    {trustedCompanies.map((name) => (
      <span>{name}</span>
    ))}
  </div>
</section>
