<dialog class="qr-lightbox" id="qr-lightbox" aria-labelledby="qr-lightbox-title" aria-modal="true">
  <form method="dialog" class="qr-lightbox-toolbar">
    <button type="submit" class="qr-lightbox-close" aria-label="Close">
      <span aria-hidden="true">×</span>
    </button>
  </form>
  <div class="qr-lightbox-body">
    <img class="qr-lightbox-img" src="" alt="" width="320" height="320" />
    <p id="qr-lightbox-title" class="qr-lightbox-title">
      <span data-en="Scan to follow on WeChat" data-zh="微信扫码关注">Scan to follow on WeChat</span>
    </p>
  </div>
</dialog>
